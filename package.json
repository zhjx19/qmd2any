{
  "name": "qmd2any",
  "displayName": "QMD2Any - Quarto 一键导出微信/知乎",
  "description": "将 Markdown / Quarto (.qmd) / Notebook (.ipynb) 一键导出到微信公众号和知乎，支持 LaTeX 公式、代码高亮、6 套主题、实时预览、Quarto 编译集成",
  "version": "2.2.1",
  "publisher": "ZhangJingxin",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#2d7a3e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Data Science"
  ],
  "keywords": [
    "markdown",
    "quarto",
    "qmd",
    "ipynb",
    "notebook",
    "jupyter",
    "wechat",
    "微信公众号",
    "知乎",
    "公式",
    "LaTeX",
    "KaTeX",
    "preview",
    "export",
    "positron",
    "rstats"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zhjx19/qmd2any"
  },
  "bugs": {
    "url": "https://github.com/zhjx19/qmd2any/issues"
  },
  "homepage": "https://github.com/zhjx19/qmd2any#readme",
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:quarto",
    "onNotebook:jupyter-notebook",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "qmd2any.preview",
        "title": "预览公众号/知乎效果",
        "category": "qmd2any",
        "icon": {
          "light": "./images/preview-icon.svg",
          "dark": "./images/preview-icon.svg"
        }
      },
      {
        "command": "qmd2any.convert",
        "title": "导出 HTML 文件",
        "category": "qmd2any",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "qmd2any.preview",
          "when": "resourceLangId == markdown || resourceLangId == quarto || resourceExtname == .ipynb",
          "group": "navigation"
        }
      ],
      "notebook/toolbar": [
        {
          "command": "qmd2any.preview",
          "when": "resourceExtname == .ipynb",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "qmd2any.preview",
          "when": "resourceExtname == .md || resourceExtname == .qmd || resourceExtname == .ipynb",
          "group": "1_modification"
        },
        {
          "command": "qmd2any.convert",
          "when": "resourceExtname == .md || resourceExtname == .qmd || resourceExtname == .ipynb",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "qmd2any.preview",
          "when": "resourceLangId == markdown || resourceLangId == quarto || resourceExtname == .ipynb",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "qmd2any.preview",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "resourceLangId == markdown || resourceLangId == quarto || resourceExtname == .ipynb"
      }
    ],
    "configuration": {
      "title": "QMD2Any",
      "properties": {
        "qmd2any.appid": {
          "type": "string",
          "default": "",
          "description": "微信公众号 AppID（用于上传草稿箱，通过 FastPen 服务）"
        },
        "qmd2any.appSecret": {
          "type": "string",
          "default": "",
          "description": "微信公众号 AppSecret（用于上传草稿箱，通过 FastPen 服务）"
        },
        "qmd2any.author": {
          "type": "string",
          "default": "",
          "description": "默认作者名称"
        },
        "qmd2any.digest": {
          "type": "string",
          "default": "",
          "description": "默认文章摘要"
        },
        "qmd2any.template": {
          "type": "string",
          "default": "wechat",
          "description": "模板名称（可在工作区 templates/ 目录下放置同名 .html 模板）"
        },
        "qmd2any.outputPath": {
          "type": "string",
          "default": "build",
          "description": "导出 HTML 的目录（相对于工作区根目录）"
        }
      }
    }
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "juice": "^9.1.0",
    "katex": "^0.16.0",
    "marked": "^11.1.1",
    "mathjax-full": "^3.2.1",
    "md5": "^2.3.0",
    "playwright-core": "^1.59.1",
    "qrcode": "^1.5.4"
  },
  "scripts": {
    "package": "vsce package",
    "install-ext": "vsce package && code --install-extension \"qmd2any-$(node -p \"require('./package.json').version\").vsix\"",
    "publish": "vsce publish",
    "start:electron": "electron ./electron/main.js",
    "build:mac": "electron-builder --mac",
    "build:mac:universal": "electron-builder --mac --universal"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
